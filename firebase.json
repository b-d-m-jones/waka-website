{
  "hosting": {
    "target": "website",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/waitlist",
        "function": "api",
        "region": "australia-southeast1"
      },
      {
        "source": "/verify",
        "function": "api",
        "region": "australia-southeast1"
      }
    ]
  }
}
